# =========================================================================
# Atlas Multimodal AI Portal — Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# ---- LLM Configuration (Groq) ----
GROQ_API_KEY="gsk_..."
BACKUP_GROQ_API_KEY="gsk_..."  # Optional backup key for automatic rotation on rate limits
GROQ_API_KEYS="gsk_...,gsk_..."  # Optional comma-separated list of multiple keys for rotation
MODEL_NAME="llama-3.3-70b-versatile"
TEMPERATURE=0.0

# ---- LangSmith Tracing (Observability) ----
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="lsv2_pt_..."
LANGCHAIN_PROJECT="multilingualchat"

# ---- Media Generation API Tokens ----
REPLICATE_API_TOKEN="r8_..."   # Optional, required for video generation
REPLICATE_VIDEO_MODEL_VERSION="stability-ai/stable-video-diffusion:3f04b56b85b77a65c8a45e99a65f02f69a56fba1051515151515151515151515"
VIDEO_GEN_MAX_POLL_SECONDS=300
VIDEO_GEN_POLL_INTERVAL_SECONDS=10
IMAGE_GEN_BASE_URL="https://image.pollinations.ai/prompt"

# ---- Memory & Persistence ----
SQLITE_DB_PATH="chatbot_memory.db"
MAX_MESSAGES_BEFORE_SUMMARY=12
KEEP_LAST_N_AFTER_SUMMARY=4

# ---- Web Server & Security ----
JWT_SECRET="generate-a-long-random-hex-string-for-production"
COOKIE_SECURE="false"  # Set to "true" in production (HTTPS)
ALLOWED_ORIGINS="http://localhost:8000"

# ---- Logging & Resilience ----
LOG_LEVEL="INFO"
MAX_LLM_RETRIES=3
RETRY_BACKOFF_SECONDS=1.5
