# =========================================================================
# Atlas Multimodal AI Portal — Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# ---- LLM Configuration (Groq) ----
GROQ_API_KEY="gsk_..."
BACKUP_GROQ_API_KEY="gsk_..."  # Optional backup key for automatic rotation on rate limits
GROQ_API_KEYS="gsk_...,gsk_..."  # Optional comma-separated list of multiple keys for rotation
MODEL_NAME="llama-3.3-70b-versatile"
TEMPERATURE=0.0

# ---- LangSmith Tracing (Observability) ----
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="lsv2_pt_..."
LANGCHAIN_PROJECT="multilingualchat"

# ---- Media Generation API Tokens ----
REPLICATE_API_TOKEN="r8_..."   # Optional, required for video generation
REPLICATE_VIDEO_MODEL_VERSION="stability-ai/stable-video-diffusion:3f04b56b85b77a65c8a45e99a65f02f69a56fba1051515151515151515151515"
VIDEO_GEN_MAX_POLL_SECONDS=300
VIDEO_GEN_POLL_INTERVAL_SECONDS=10
IMAGE_GEN_BASE_URL="https://image.pollinations.ai/prompt"

# ---- Memory & Persistence ----
SQLITE_DB_PATH="chatbot_memory.db"
MAX_MESSAGES_BEFORE_SUMMARY=12
KEEP_LAST_N_AFTER_SUMMARY=4

# ---- Web Server & Security ----
JWT_SECRET="generate-a-long-random-hex-string-for-production"
COOKIE_SECURE="false"  # Set to "true" in production (HTTPS)
ALLOWED_ORIGINS="http://localhost:8000"

# ---- Logging & Resilience ----
LOG_LEVEL="INFO"
MAX_LLM_RETRIES=3
RETRY_BACKOFF_SECONDS=1.5

# ---- MCP (Model Context Protocol) ----
# ─────────────────────────────────────────────────────────────────────────────
# Set MCP_ENABLED=true to activate the MCP client.
# Then configure MCP_SERVERS_JSON to specify which external servers to connect.
# You can also connect/disconnect servers at runtime via the API:
#   POST /mcp/connect    — connect a server (no restart needed)
#   POST /mcp/disconnect — disconnect a server
#   GET  /mcp/registry   — browse the built-in server catalogue
# ─────────────────────────────────────────────────────────────────────────────
MCP_ENABLED="false"
MCP_TIMEOUT=30

# Atlas's own MCP server settings (run: python mcp_server.py)
MCP_SERVER_HOST="127.0.0.1"
MCP_SERVER_PORT=9000

# ── MCP_SERVERS_JSON: static servers loaded at startup ──────────────────────
# (Runtime connect via POST /mcp/connect is preferred for most users)
# Format: {"server_id": {"transport": "stdio|streamable_http", ...}, ...}
MCP_SERVERS_JSON=""

# ── Google Services ──────────────────────────────────────────────────────────
# Required for: google_drive, gmail, google_calendar
# Get credentials at: https://console.developers.google.com
GDRIVE_CLIENT_ID=""
GDRIVE_CLIENT_SECRET=""
GDRIVE_REFRESH_TOKEN=""

GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""

# ── GitHub ───────────────────────────────────────────────────────────────────
# Required for: github
# Create at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=""

# ── GitLab ───────────────────────────────────────────────────────────────────
# Required for: gitlab
GITLAB_PERSONAL_ACCESS_TOKEN=""
GITLAB_API_URL="https://gitlab.com"      # Override for self-hosted GitLab

# ── Slack ────────────────────────────────────────────────────────────────────
# Required for: slack
# Create a Slack App at: https://api.slack.com/apps
SLACK_BOT_TOKEN=""                        # xoxb-...
SLACK_TEAM_ID=""                          # T...

# ── Notion ───────────────────────────────────────────────────────────────────
# Required for: notion
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=""                         # secret_...

# ── Brave Search ─────────────────────────────────────────────────────────────
# Required for: brave_search
# Get at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=""

# ── AWS Bedrock Knowledge Base ────────────────────────────────────────────────
# Required for: aws_kb_retrieval
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required for: postgres
# (Also accepted as a runtime param via POST /mcp/connect)
PG_CONNECTION_STRING=""                   # postgresql://user:pass@host:5432/db

# ── Custom HTTP MCP Server ────────────────────────────────────────────────────
# (Can also be connected at runtime — no env vars needed)
# MCP_SERVER_MYSERVER_URL="http://localhost:9001/mcp"
# MCP_SERVER_MYSERVER_COMMAND="python my_local_mcp_server.py"
